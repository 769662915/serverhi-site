---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Disclaimer - ServerHi">
  <div class="container">
    <article class="legal-page">
      <header class="page-header fade-in-up">
        <h1 class="page-title">
          <span class="terminal-prompt"></span>
          Disclaimer
        </h1>
        <p class="last-updated">Last updated: June 18, 2026</p>
      </header>

      <div class="content-wrapper">
        <div class="legal-content fade-in-up">
          <section class="legal-section">
            <h2>General Disclaimer</h2>
            <p>
              The information provided on ServerHi (serverhi.com) is for educational and informational
              purposes only. All content, including tutorials, guides, code examples, and configuration
              instructions, is provided "as is" without warranty of any kind.
            </p>
          </section>

          <section class="legal-section">
            <h2>Use at Your Own Risk</h2>
            <p>
              Server administration involves inherent risks. Following any tutorial or guide on this
              website may result in system changes, data loss, or service interruptions. You assume full
              responsibility for any actions taken based on the information provided here.
            </p>
            <p>We strongly recommend that you:</p>
            <ul>
              <li>Back up your systems before following any tutorials</li>
              <li>Test commands and configurations in a non-production environment first</li>
              <li>Understand what each command does before executing it</li>
              <li>Consult official documentation for critical production systems</li>
              <li>Adapt instructions to your specific environment and requirements</li>
            </ul>
          </section>

          <section class="legal-section">
            <h2>No Professional Advice</h2>
            <p>
              Content on ServerHi does not constitute professional IT consulting, legal advice, or
              security auditing. While our team has extensive experience, every environment is unique.
              For mission-critical systems, consult with qualified professionals who can assess your
              specific situation.
            </p>
          </section>

          <section class="legal-section">
            <h2>Accuracy of Information</h2>
            <p>
              While we strive to provide accurate and up-to-date information, we make no guarantees
              regarding the completeness, accuracy, or reliability of the content. Software versions
              change, best practices evolve, and what works today may not work tomorrow.
            </p>
            <p>
              We update our tutorials regularly but cannot guarantee that all content reflects the
              latest software versions or security requirements at any given time.
            </p>
          </section>

          <section class="legal-section">
            <h2>Third-Party Links</h2>
            <p>
              ServerHi may contain links to third-party websites, tools, or services. We do not control
              these external resources and are not responsible for their content, availability, or
              practices. Including a link does not imply endorsement.
            </p>
          </section>

          <section class="legal-section">
            <h2>Limitation of Liability</h2>
            <p>
              In no event shall ServerHi, its contributors, or its editors be liable for any direct,
              indirect, incidental, consequential, or punitive damages arising from your access to,
              use of, or inability to use the materials on this website. This includes but is not
              limited to damages for loss of data, profits, business interruption, or system downtime.
            </p>
          </section>

          <section class="legal-section">
            <h2>Code Examples</h2>
            <p>
              Code snippets, scripts, and configuration files provided in tutorials are shared for
              educational purposes. While we test our examples, you should review and understand any
              code before running it on your systems. We are not responsible for any damage caused by
              the use or misuse of code examples found on this site.
            </p>
          </section>

          <section class="legal-section">
            <h2>Changes to This Disclaimer</h2>
            <p>
              We may update this disclaimer at any time. Changes are effective immediately upon posting.
              Your continued use of the site constitutes acceptance of the updated disclaimer.
            </p>
          </section>

          <section class="legal-section">
            <h2>Contact</h2>
            <p>If you have questions about this disclaimer, please contact us:</p>
            <ul>
              <li>Email: <a href="mailto:legal@serverhi.com">legal@serverhi.com</a></li>
              <li>Contact Form: <a href="/contact">Contact Us</a></li>
            </ul>
          </section>
        </div>
      </div>
    </article>
  </div>
</BaseLayout>

<style>
  .legal-page {
    padding: 2rem 0;
  }

  .page-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .page-title {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .last-updated {
    color: var(--text-secondary);
    font-family: var(--font-code);
    font-size: 0.9rem;
  }

  .legal-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .legal-section {
    margin-bottom: 3rem;
  }

  .legal-section h2 {
    font-size: 1.75rem;
    margin-bottom: 1rem;
    color: var(--primary);
  }

  .legal-section h3 {
    font-size: 1.25rem;
    margin: 1.5rem 0 0.75rem;
    color: var(--text);
  }

  .legal-section p {
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .legal-section ul {
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 1rem;
    padding-left: 2rem;
  }

  .legal-section li {
    margin-bottom: 0.5rem;
  }

  .legal-section a {
    color: var(--accent);
    text-decoration: none;
  }

  .legal-section a:hover {
    color: var(--primary);
    text-decoration: underline;
  }

  .legal-section strong {
    color: var(--text);
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .page-title {
      font-size: 2rem;
    }

    .legal-section h2 {
      font-size: 1.5rem;
    }
  }
</style>
